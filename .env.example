# Copy to .env and fill in your values
RAG_PROVIDER=openai        # openai | anthropic | ollama

# Required secrets
JWT_SECRET=change-me-to-a-256-bit-random-secret
DB_PASSWORD=change-me

# Database (optional overrides)
DB_USERNAME=raguser
DB_NAME=ragdb

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (only needed if RAG_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Custom base URLs (for proxy/relay services)
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model overrides (optional)
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_MODEL=llama3.2

# Registration (set to true to allow new user signups)
RAG_REGISTRATION_ENABLED=false
